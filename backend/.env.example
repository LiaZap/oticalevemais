# =============================================
# Ótica Leve Mais — Backend Environment Variables
# =============================================
# Copie este arquivo para .env e preencha os valores

# ---- Database ----
DATABASE_URL=postgresql://usuario:senha@localhost:5432/oticalevemais
# OU configure individualmente:
# DB_USER=usuario
# DB_HOST=localhost
# DB_NAME=oticalevemais
# DB_PASSWORD=sua_senha
# DB_PORT=5432

# ---- JWT ----
JWT_SECRET=gere_um_segredo_forte_aqui_com_32_chars_min

# ---- OpenAI (IA Íris) ----
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4.1-mini

# ---- Uazapi (WhatsApp) ----
UAZAPI_URL=https://sua-instancia.uazapi.com
UAZAPI_TOKEN=seu-token-uazapi

# ---- URLs ----
FRONTEND_URL=https://seu-dominio.com
BACKEND_URL=https://seu-backend.com

# ---- Ambiente ----
NODE_ENV=production
PORT=5000
